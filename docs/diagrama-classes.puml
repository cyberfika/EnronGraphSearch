@startuml Enron_ContactGraph_Classes

skinparam classAttributeIconSize 0
skinparam classFontSize 12
skinparam packageStyle rectangle
skinparam linetype ortho

package "br.edu.enron.model" {

    class Vertex {
        - email : String
        + Vertex(email : String)
        + getEmail() : String
        + equals(obj : Object) : boolean
        + hashCode() : int
        + toString() : String
    }

    class Edge {
        - origin : Vertex
        - destination : Vertex
        - weight : int
        + Edge(origin : Vertex, destination : Vertex)
        + getOrigin() : Vertex
        + getDestination() : Vertex
        + getWeight() : int
        + incrementWeight() : void
        + getInverseCost() : double
        + toString() : String
    }

    class EmailMessage {
        - sender : String
        - recipients : List<String>
        + EmailMessage(sender : String, recipients : List<String>)
        + getSender() : String
        + getRecipients() : List<String>
        + hasValidData() : boolean
        + toString() : String
    }

    class DegreeResult {
        - email : String
        - degree : int
        + DegreeResult(email : String, degree : int)
        + getEmail() : String
        + getDegree() : int
        + compareTo(other : DegreeResult) : int
        + toString() : String
    }

    class PathResult {
        - vertices : List<Vertex>
        - totalCost : double
        - accumulatedDependency : double
        + PathResult(vertices : List<Vertex>)
        + PathResult(vertices : List<Vertex>, totalCost : double, accDep : double)
        + getVertices() : List<Vertex>
        + getTotalCost() : double
        + getAccumulatedDependency() : double
        + exists() : boolean
        + toString() : String
    }
}

package "br.edu.enron.graph" {

    class ContactGraph <<Serializable>> {
        - vertexIndex : Map<String, Vertex>
        - adjacency : Map<Vertex, Map<Vertex, Edge>>
        + ContactGraph()
        + addVertex(email : String) : Vertex
        + addEdge(originEmail : String, destinationEmail : String) : void
        + findVertex(email : String) : Optional<Vertex>
        + containsVertex(email : String) : boolean
        + getVertices() : Collection<Vertex>
        + getEdges() : List<Edge>
        + getOutEdges(vertex : Vertex) : List<Edge>
        + getInEdges(vertex : Vertex) : List<Edge>
        + vertexCount() : int
        + edgeCount() : int
        + outDegree(vertex : Vertex) : int
        + inDegree(vertex : Vertex) : int
    }
}

package "br.edu.enron.service" {

    class ContactAnalyzer {
        - graph : ContactGraph
        + ContactAnalyzer(graph : ContactGraph)
        + getVertexCount() : int
        + getEdgeCount() : int
        + getTop20OutDegree() : List<DegreeResult>
        + getTop20InDegree() : List<DegreeResult>
    }

    class DepthFirstSearch {
        + search(graph : ContactGraph, originEmail : String, destinationEmail : String) : PathResult
    }

    class BreadthFirstSearch {
        + search(graph : ContactGraph, originEmail : String, destinationEmail : String) : PathResult
    }

    class DistanceCalculator {
        + getVerticesAtDistance(graph : ContactGraph, originEmail : String, distance : int) : List<Vertex>
    }

    class CriticalPathService {
        + computeCriticalPath(graph : ContactGraph, originEmail : String, destinationEmail : String) : PathResult
    }
}

package "br.edu.enron.parser" {

    class EmailParser {
        + parse(rawContent : String) : EmailMessage
    }

    class EnronDatasetReader {
        - parser : EmailParser
        + buildGraph(datasetRoot : Path) : ContactGraph
        + loadFromCache(cacheFile : Path) : ContactGraph
        + saveToCache(graph : ContactGraph, cacheFile : Path) : void
    }
}

package "br.edu.enron.util" {

    class EmailValidator <<utility>> {
        + {static} normalize(email : String) : String
        + {static} isValid(email : String) : boolean
    }
}

package "br.edu.enron.view" {

    class GraphVisualizer {
        + display(contactGraph : ContactGraph, title : String) : void
        + displayWithPath(contactGraph : ContactGraph, pathResult : PathResult, title : String, label : String) : void
    }
}

package "br.edu.enron.app" {

    class Main {
        + {static} main(args : String[]) : void
    }
}

' --- Relationships ---

Edge "1" --> "1" Vertex : origin
Edge "1" --> "1" Vertex : destination

ContactGraph "1" o-- "*" Vertex : contains
ContactGraph "1" o-- "*" Edge   : contains

PathResult "*" --> "*" Vertex : lists

ContactAnalyzer  --> ContactGraph : uses
DepthFirstSearch  --> ContactGraph : uses
BreadthFirstSearch --> ContactGraph : uses
DistanceCalculator --> ContactGraph : uses
CriticalPathService --> ContactGraph : uses

ContactAnalyzer  ..> DegreeResult : produces
DepthFirstSearch  ..> PathResult  : produces
BreadthFirstSearch ..> PathResult : produces
CriticalPathService ..> PathResult : produces
DistanceCalculator ..> Vertex     : produces

EnronDatasetReader --> EmailParser  : uses
EnronDatasetReader ..> EmailMessage : produces
EnronDatasetReader ..> ContactGraph : builds

EmailParser ..> EmailMessage : produces
EmailParser ..> EmailValidator : uses

GraphVisualizer --> ContactGraph : reads
GraphVisualizer --> PathResult   : reads

Main --> EnronDatasetReader  : uses
Main --> ContactAnalyzer     : uses
Main --> DepthFirstSearch    : uses
Main --> BreadthFirstSearch  : uses
Main --> DistanceCalculator  : uses
Main --> CriticalPathService : uses
Main --> GraphVisualizer     : uses

@enduml
